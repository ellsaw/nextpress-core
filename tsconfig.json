{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "rootDir": "lib/nextjs-lib",
    "declaration": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": false,
    "noUncheckedIndexedAccess": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@nextpress/*": ["./lib/nextjs-lib/*"]
    }
  },
  "include": [
    "lib/nextjs-lib/**/*.ts",
    "lib/nextjs-lib/**/*.tsx",
    "lib/nextjs-lib/**/*.mts"
  ],
  "exclude": ["node_modules", "dist"]
}
